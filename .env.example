# =============================================================
# WhatsApp Atendimento — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ---------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ---------------------------------------------------------------
DATABASE_URL=postgresql://wa:wapassword@localhost:5432/wa_atendimento

# ---------------------------------------------------------------
# Redis (cache, filas BullMQ, pub/sub Socket.IO)
# Formato: redis://HOST:PORT ou redis://:PASSWORD@HOST:PORT
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------
# MinIO (armazenamento de mídia: imagens, áudios, vídeos, docs)
# ---------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=whatsapp-media
# Use false em desenvolvimento local, true em produção com HTTPS
MINIO_USE_SSL=false

# ---------------------------------------------------------------
# JWT — Tokens de autenticação
# Gere com: openssl rand -base64 32
# NUNCA use os valores de exemplo em produção!
# ---------------------------------------------------------------
JWT_SECRET=super-secret-jwt-key-dev-only-32chars!!
JWT_REFRESH_SECRET=super-secret-refresh-key-dev-32ch!!

# ---------------------------------------------------------------
# Criptografia de sessões WhatsApp (Baileys)
# Deve ter exatamente 32 caracteres (256 bits)
# Gere com: openssl rand -hex 16
# ---------------------------------------------------------------
SESSION_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ---------------------------------------------------------------
# Servidor API (Fastify)
# ---------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------
# CORS — URL do frontend permitido
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------
# Logging (pino)
# Níveis: trace | debug | info | warn | error | fatal
# ---------------------------------------------------------------
LOG_LEVEL=debug
