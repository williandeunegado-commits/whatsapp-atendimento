{
  "name": "whatsapp-atendimento",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de atendimento WhatsApp multi-agente",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @wa/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @wa/api exec prisma studio",
    "db:seed": "pnpm --filter @wa/api exec prisma db seed",
    "db:reset": "pnpm --filter @wa/api exec prisma migrate reset --force",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
